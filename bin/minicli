#!/usr/bin/php
<?php

if (php_sapi_name() !== 'cli') {
    exit;
}

define("APP_ROOT", "/app");

require APP_ROOT . '/vendor/autoload.php';

use Minicli\App;
use Minicli\Command\CommandCall;

$app = new App();
$app->setSignature('./bin/minicli update');
$input = new CommandCall($argv);

$app->registerCommand('update', function () use ($app, $input) {

    $app->newline();
    $app->info("Downloading csv file.");

    $fileRemote = 'https://www.istat.it/storage/codici-unita-amministrative/Elenco-comuni-italiani.csv';
    $data = file_get_contents($fileRemote);
    $fileCsv = APP_ROOT . '/data.csv';
    file_put_contents($fileCsv, mb_convert_encoding($data, 'UTF-8', 'ISO-8859-1'));

    $app->info("Converting csv to json.");

    $fileJson = APP_ROOT . '/data.json';
    $json = csvToJson($fileCsv);
    file_put_contents($fileJson, $json);

    $app->info("Data updated.");
    $app->newline();

    return 0;
});

$app->runCommand($input->getRawArgs());


// php function to convert csv to json format
function csvToJson($fname)
{
    // open csv file
    if (!($fp = fopen($fname, 'r'))) {
        die("Can't open file...");
    }

    //read csv headers
    $key = fgetcsv($fp, "1024", ";");

    // parse csv rows into array
    $json = array();
    while ($row = fgetcsv($fp, "1024", ";")) {
        $json[] = array_combine($key, $row);
    }

    // release file handle
    fclose($fp);

    // encode array to json
    return json_encode($json);
}



